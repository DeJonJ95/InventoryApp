rules_version = '2';

// Only signed-in Firebase Auth users can read the PAMS CSV exports.
// Writes are always denied to clients — the daily Cloud Function writes
// via the Admin SDK, which bypasses these rules entirely.
service firebase.storage {
  match /b/{bucket}/o {

    match /exports/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Item photos: public read (just product pictures — keeps the <img>
    // simple, no token needed); only signed-in users can upload/replace.
    match /item-images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Everything else is locked down.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
